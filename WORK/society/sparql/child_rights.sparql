# SPARQL-запрос: Декларация прав ребёнка и связанные законы
# Источник: Wikidata
# Раздел 1: Мои права и обязанности

SELECT ?item ?itemLabel ?typeLabel WHERE {
  {
    ?item wdt:P31 wd:Q181258.
  }
  UNION
  {
    ?item wdt:P31 wd:Q132924.
  }
  UNION
  {
    ?item wdt:P921 wd:Q179860.
  }
  ?item wdt:P31 ?type.
  SERVICE wikibase:label { bd:serviceParam wikibase:language "ru,en". }
}
LIMIT 30
